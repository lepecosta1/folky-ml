# ===== Mercado Livre (App de desenvolvedor da conta da Folky) =====
# Crie o App em https://developers.mercadolivre.com.br/devcenter/create-app
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Tem que ser EXATAMENTE igual a "Redirect URI" cadastrada no App (com https).
ML_REDIRECT_URI=https://SEU-PROJETO.vercel.app/api/auth/callback

# ===== Armazenamento (Upstash Redis via Vercel Marketplace) =====
# Guarda o token da ML (com refresh) e o historico diario p/ analise de tendencia.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== IA que analisa a conta (Anthropic / Claude) =====
# Crie a chave em https://console.anthropic.com
ANTHROPIC_API_KEY=

# ===== Seguranca da rotina diaria (cron) =====
# Crie um valor aleatorio qualquer; a Vercel envia esse segredo no header do cron.
CRON_SECRET=
